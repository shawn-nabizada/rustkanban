# RustKanban Sync Server -- Environment Variables
#
# Copy this file to the project root as .env and fill in the values.
# When using docker compose, the .env file is loaded automatically.

# -- Database -----------------------------------------------------------------
# When running via docker compose, this is set automatically. Only override if
# you are running the server outside of Docker or using an external database.
# DATABASE_URL=postgres://rustkanban:rustkanban@localhost:5432/rustkanban

# -- GitHub OAuth -------------------------------------------------------------
# Create an OAuth app at https://github.com/settings/developers
# Set the callback URL to: <SERVER_URL>/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -- Server -------------------------------------------------------------------
# Public URL of the server (used for OAuth redirect URIs).
SERVER_URL=http://localhost:3000

# Secret used for session/token signing. Generate a random string for production.
SESSION_SECRET=dev-secret-change-me-in-production

# Port the server listens on.
PORT=3000

# -- Logging ------------------------------------------------------------------
# See https://docs.rs/tracing-subscriber/latest/tracing_subscriber/struct.EnvFilter.html
RUST_LOG=info
